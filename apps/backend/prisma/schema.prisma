generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CatalogItemType {
  PRODUCT
  SERVICE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum CatalogItemDiscountType {
  PERCENTAGE
  FIXED
}

// ─── Multi-tenant ───

model Organization {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  logoUrl        String?
  modulesEnabled String[] @default([])
  status         String   @default("active") // active, suspended, inactive
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  users            User[]
  roles            Role[]
  catalogItems     CatalogItem[]
  tags             Tag[]
  categories       Category[]
  orders           Order[]
  campaigns        Campaign[]
  systemSettings   SystemSetting[]
  apiKeys          ApiKey[]
  reviews          Review[]
  homepageSections HomepageSection[]
  homepageBanners  HomepageBanner[]
}

// ─── Auth & Users ───

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  password       String
  name           String?
  active         Boolean  @default(true)
  modulesEnabled String[] @default([])
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roles        UserRole[]

  @@index([organizationId])
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

// ─── Roles & Permissions ───

model Role {
  id             String  @id @default(uuid())
  name           String
  description    String?
  organizationId String

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissions  RolePermission[]
  users        UserRole[]

  @@unique([name, organizationId])
  @@index([organizationId])
}

model Permission {
  id       String @id @default(uuid())
  resource String
  action   String
  name     String

  roles RolePermission[]

  @@unique([resource, action])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ─── Catalog ───

model CatalogItem {
  id               String          @id @default(uuid())
  name             String
  slug             String
  description      String?
  price            Float
  comparePrice     Float?
  discountType     CatalogItemDiscountType?
  discountValue    Float                  @default(0)
  type             CatalogItemType
  sku              String?
  barcode          String?
  active           Boolean         @default(true)
  visibility       String          @default("visible")
  featured         Boolean         @default(false)
  label            String?
  organizationId   String
  categoryId       String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Detalles del producto
  brand            String?
  material         String?
  gender           String?
  season           String?
  fit              String?
  weight           Float?
  dimensions       String?
  country          String?
  careInstructions String?

  // SEO
  metaTitle        String?
  metaDescription  String?

  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category       Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags           CatalogItemTag[]
  media          Media[]
  inventory      Inventory?
  reviews        Review[]
  variants       CatalogItemVariant[]
  spotlights     HomepageProductSpotlight[]

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@index([categoryId])
}

model CatalogItemVariant {
  id            String   @id @default(uuid())
  catalogItemId String
  name          String
  sku           String?
  color         String?
  colorHex      String?
  size          String?
  price         Float?
  stock         Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  catalogItem CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)

  @@index([catalogItemId])
}

model Tag {
  id             String @id @default(uuid())
  name           String
  slug           String
  organizationId String

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  catalogItems CatalogItemTag[]

  @@unique([slug, organizationId])
  @@index([organizationId])
}

model Review {
  id             String   @id @default(uuid())
  catalogItemId  String
  userName       String
  userEmail      String?
  rating         Int      @default(5)
  comment        String
  createdAt      DateTime @default(now())
  organizationId String

  catalogItem  CatalogItem  @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([catalogItemId])
  @@index([organizationId])
}

model CatalogItemTag {
  catalogItemId String
  tagId         String

  catalogItem CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  tag         Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([catalogItemId, tagId])
}

model Category {
  id             String  @id @default(uuid())
  name           String
  slug           String
  parentId       String?
  organizationId String

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       Category?     @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[]    @relation("CategoryTree")
  catalogItems CatalogItem[]

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@index([parentId])
}

// ─── Media ───

model Media {
  id            String    @id @default(uuid())
  url           String
  type          MediaType
  alt           String?
  order         Int       @default(0)
  catalogItemId String
  createdAt     DateTime  @default(now())

  catalogItem CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)

  @@index([catalogItemId])
}

// ─── Orders ───

model Order {
  id               String      @id @default(uuid())
  status           OrderStatus @default(PENDING)
  subtotal         Float
  discount         Float       @default(0)
  total            Float
  customerName     String
  customerEmail    String
  customerPhone    String?
  notes            String?
  couponCode       String?
  
  // Shipping / Logistics
  shippingAddress  String?
  shippingCity     String?
  shippingState    String?
  shippingZip      String?
  shippingCountry  String?
  carrier          String?
  trackingNumber   String?
  shippedAt        DateTime?
  deliveredAt      DateTime?
  
  organizationId   String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        OrderItem[]

  @@index([organizationId])
  @@index([status])
}

model OrderItem {
  id              String @id @default(uuid())
  orderId         String
  catalogItemId   String
  catalogItemName String
  quantity        Int
  unitPrice       Float
  totalPrice      Float

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// ─── Inventory ───

model Inventory {
  id                String @id @default(uuid())
  catalogItemId     String @unique
  quantity          Int    @default(0)
  lowStockThreshold Int    @default(5)

  catalogItem CatalogItem     @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  movements   StockMovement[]
  batches     InventoryBatch[]
}

model InventoryBatch {
  id                String   @id @default(uuid())
  inventoryId       String
  batchNumber       String
  quantity          Int
  remainingQuantity Int      @default(0)
  costPerUnit       Float?
  receivedAt        DateTime @default(now())
  expiresAt         DateTime?
  supplier          String?
  notes             String?
  createdBy         String?
  createdAt         DateTime @default(now())

  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([inventoryId])
  @@index([batchNumber])
}

model StockMovement {
  id          String       @id @default(uuid())
  inventoryId String
  type        MovementType
  quantity    Int
  reason      String?
  reference   String?
  createdBy   String?
  createdAt   DateTime     @default(now())

  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([inventoryId])
}

// ─── Campaigns & Discounts ───

model Campaign {
  id             String   @id @default(uuid())
  name           String
  description    String?
  startDate      DateTime
  endDate        DateTime
  active         Boolean  @default(true)
  autoApply      Boolean  @default(false)
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  discounts    Discount[]

  @@index([organizationId])
  @@index([active, startDate, endDate])
}

model Discount {
  id         String       @id @default(uuid())
  type       DiscountType
  value      Float
  code       String?
  maxUses    Int?
  usedCount  Int          @default(0)
  campaignId String

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([code])
  @@index([campaignId])
}

// ─── Company Settings ───

model SystemSetting {
  id             String @id @default(uuid())
  key            String
  value          String
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
}

model ApiKey {
  id             String   @id @default(uuid())
  name           String
  keyHash        String   @unique
  keyPrefix      String
  permissions    String[] @default([])
  active         Boolean  @default(true)
  lastUsedAt     DateTime?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([keyHash])
}

// ─── Content Site Web ───

model HomepageSection {
  id             String   @id @default(uuid())
  type           String   // hero, featured, new_arrivals, promo, collections
  title          String?
  order          Int      @default(0)
  active         Boolean  @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slides       HomepageSlide[]
  spotlights   HomepageProductSpotlight[]
  banners      HomepageBanner[]

  @@index([organizationId])
  @@index([type])
}

model HomepageSlide {
  id        String  @id @default(uuid())
  sectionId String
  imageUrl  String
  title     String?
  subtitle  String?
  ctaText   String?
  ctaLink   String?
  order     Int     @default(0)
  active    Boolean @default(true)

  section HomepageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
}

model HomepageProductSpotlight {
  id            String @id @default(uuid())
  sectionId     String
  catalogItemId String
  order         Int    @default(0)

  section     HomepageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  catalogItem CatalogItem     @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)

  @@unique([sectionId, catalogItemId])
  @@index([sectionId])
  @@index([catalogItemId])
}

model HomepageBanner {
  id             String  @id @default(uuid())
  sectionId      String?
  imageUrl       String?
  title          String?
  description    String?
  link           String?
  position       String? // ej: "top", "middle", "bottom"
  active         Boolean @default(true)
  order          Int     @default(0)
  organizationId String

  organization  Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  section       HomepageSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([sectionId])
}
