generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CatalogItemType {
  PRODUCT
  SERVICE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum CatalogItemDiscountType {
  PERCENTAGE
  FIXED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  CASH
  BANK_TRANSFER
  MERCADOPAGO
  STRIPE
  PAYPAL
  OTHER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIAL
}

enum ShippingStatus {
  PENDING
  READY
  SHIPPED
  IN_TRANSIT
  DELIVERED
  RETURNED
}

// ─── Multi-tenant ───

model Organization {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  logoUrl        String?
  modulesEnabled String[] @default([])
  status         String   @default("active") // active, suspended, inactive
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  users            User[]
  roles            Role[]
  catalogItems     CatalogItem[]
  tags             Tag[]
  categories       Category[]
  orders           Order[]
  customers        Customer[]
  shippingMethods  ShippingMethod[]
  campaigns        Campaign[]
  systemSettings   SystemSetting[]
  apiKeys          ApiKey[]
  reviews          Review[]
  homepageSections HomepageSection[]
  homepageBanners  HomepageBanner[]
  drivers          Driver[]
  deliveryZones    DeliveryZone[]
  deliveryRoutes   DeliveryRoute[]
  locations        Location[]
  returns          Return[]
  invitations      Invitation[]
}

// ─── Auth & Users ───

model User {
  id             String   @id @default(uuid())
  email          String
  password       String
  name           String?
  active         Boolean  @default(true)
  modulesEnabled String[] @default([])
  organizationId String
  invitedBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roles        UserRole[]
  driver       Driver?

  @@unique([email, organizationId])
  @@index([organizationId])
}

model Invitation {
  id             String    @id @default(uuid())
  token          String    @unique
  email          String
  name           String?
  organizationId String
  roleIds        String[]
  modulesEnabled String[]  @default([])
  invitedBy      String
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([token])
  @@index([email, organizationId])
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

// ─── Roles & Permissions ───

model Role {
  id             String  @id @default(uuid())
  name           String
  description    String?
  organizationId String

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissions  RolePermission[]
  users        UserRole[]

  @@unique([name, organizationId])
  @@index([organizationId])
}

model Permission {
  id       String @id @default(uuid())
  resource String
  action   String
  name     String

  roles RolePermission[]

  @@unique([resource, action])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ─── Catalog ───

model CatalogItem {
  id               String          @id @default(uuid())
  name             String
  slug             String
  description      String?
  price            Float
  comparePrice     Float?
  discountType     CatalogItemDiscountType?
  discountValue    Float                  @default(0)
  type             CatalogItemType
  sku              String?
  barcode          String?
  active           Boolean         @default(true)
  visibility       String          @default("visible")
  featured         Boolean         @default(false)
  label            String?
  organizationId   String
  categoryId       String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Detalles del producto
  brand            String?
  material         String?
  gender           String?
  season           String?
  fit              String?
  weight           Float?
  dimensions       String?
  country          String?
  careInstructions String?

  // SEO
  metaTitle        String?
  metaDescription  String?

  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category       Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags           CatalogItemTag[]
  media          Media[]
  inventory      Inventory?
  reviews        Review[]
  variants       CatalogItemVariant[]
  spotlights     HomepageProductSpotlight[]

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@index([categoryId])
}

model CatalogItemVariant {
  id            String   @id @default(uuid())
  catalogItemId String
  name          String
  sku           String?
  color         String?
  colorHex      String?
  size          String?
  price         Float?
  stock         Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  catalogItem CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)

  @@index([catalogItemId])
}

model Tag {
  id             String @id @default(uuid())
  name           String
  slug           String
  organizationId String

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  catalogItems CatalogItemTag[]

  @@unique([slug, organizationId])
  @@index([organizationId])
}

model Review {
  id             String   @id @default(uuid())
  catalogItemId  String
  userName       String
  userEmail      String?
  rating         Int      @default(5)
  comment        String
  createdAt      DateTime @default(now())
  organizationId String

  catalogItem  CatalogItem  @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([catalogItemId])
  @@index([organizationId])
}

model CatalogItemTag {
  catalogItemId String
  tagId         String

  catalogItem CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  tag         Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([catalogItemId, tagId])
}

model Category {
  id             String  @id @default(uuid())
  name           String
  slug           String
  parentId       String?
  organizationId String

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       Category?     @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[]    @relation("CategoryTree")
  catalogItems CatalogItem[]

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@index([parentId])
}

// ─── Media ───

model Media {
  id            String    @id @default(uuid())
  url           String
  type          MediaType
  alt           String?
  order         Int       @default(0)
  catalogItemId String
  createdAt     DateTime  @default(now())

  catalogItem CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)

  @@index([catalogItemId])
}

// ─── Orders ───

model Order {
  id                String         @id @default(uuid())
  status            OrderStatus    @default(PENDING)
  paymentStatus     PaymentStatus  @default(PENDING)
  subtotal          Float
  discount          Float          @default(0)
  tax               Float          @default(0)
  shippingCost      Float          @default(0)
  total             Float
  overpaidAmount    Float          @default(0) // Saldo a favor del cliente
  
  // Customer (puede ser registrado o guest)
  customerId        String?
  customerName      String
  customerEmail     String
  customerPhone     String?
  
  // Shipping
  shippingAddressId String?
  shippingMethodId  String?
  shippingAddress   String?        // fallback si no hay customer registrado
  shippingCity      String?
  shippingState     String?
  shippingZip       String?
  shippingCountry   String?
  shippingStatus    ShippingStatus @default(PENDING)
  carrier           String?
  trackingNumber    String?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  estimatedDelivery DateTime?
  
  notes               String?
  internalNotes       String?
  couponCode          String?
  
  // Delivery logistics
  driverId            String?
  deliveryZoneId      String?
  deliveryInstructions String?
  deliveryTimeWindow  String?        // JSON: {from: "09:00", to: "14:00"}
  attemptCount        Int            @default(0)
  proofOfDelivery     String?        // JSON: {photoUrl, signatureUrl, deliveredTo}
  
  // Cancellation tracking
  cancelledAt         DateTime?
  cancellationReason  String?
  refundedAmount      Float          @default(0) // Monto reembolsado por cancelación
  
  organizationId      String
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  shippingMethod ShippingMethod? @relation(fields: [shippingMethodId], references: [id], onDelete: SetNull)
  driver         Driver?         @relation(fields: [driverId], references: [id], onDelete: SetNull)
  deliveryZone   DeliveryZone?   @relation(fields: [deliveryZoneId], references: [id], onDelete: SetNull)
  items          OrderItem[]
  payments       Payment[]
  delivery       Delivery?
  returns        Return[]

  @@index([organizationId])
  @@index([status])
  @@index([customerId])
  @@index([paymentStatus])
  @@index([driverId])
  @@index([deliveryZoneId])
}

model OrderItem {
  id              String @id @default(uuid())
  orderId         String
  catalogItemId   String
  catalogItemName String
  quantity        Int
  unitPrice       Float
  totalPrice      Float

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// ─── Logistics ───

model Driver {
  id             String   @id @default(uuid())
  name           String
  email          String?
  phone          String
  licenseNumber  String?
  vehicleType    String?  // moto, auto, camioneta, bicicleta
  licensePlate   String?
  active         Boolean  @default(true)
  currentLat     Float?
  currentLng     Float?
  lastLocationAt DateTime?
  userId         String?  @unique
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  orders       Order[]
  deliveries   Delivery[]
  routes       DeliveryRoute[]
  pickups      Return[]

  @@index([organizationId])
  @@index([userId])
  @@index([active])
}

model Delivery {
  id                String         @id @default(uuid())
  orderId           String         @unique
  driverId          String
  status            DeliveryStatus @default(ASSIGNED)
  assignedAt        DateTime       @default(now())
  startedAt         DateTime?
  completedAt       DateTime?
  failedAt          DateTime?
  estimatedArrival  DateTime?
  actualArrival     DateTime?
  notes             String?
  failureReason     String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driver       Driver       @relation(fields: [driverId], references: [id], onDelete: Cascade)
  trackingEvents TrackingEvent[]

  @@index([orderId])
  @@index([driverId])
  @@index([status])
}

model TrackingEvent {
  id          String   @id @default(uuid())
  deliveryId  String
  status      String   // in_transit, nearby, arrived, completed, failed
  latitude    Float?
  longitude   Float?
  address     String?
  notes       String?
  timestamp   DateTime @default(now())

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
  @@index([timestamp])
}

model DeliveryZone {
  id             String  @id @default(uuid())
  name           String
  coordinates    String  // JSON polygon array
  shippingCost   Float   @default(0)
  estimatedDays  Int     @default(1)
  color          String  @default("#3b82f6")
  active         Boolean @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@index([organizationId])
  @@index([active])
}

model DeliveryRoute {
  id          String   @id @default(uuid())
  name        String
  driverId    String
  date        DateTime @default(now())
  status      RouteStatus @default(PLANNED)
  orderIds    String[] // Array of order IDs
  startedAt   DateTime?
  completedAt DateTime?
  notes       String?
  organizationId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  driver       Driver       @relation(fields: [driverId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([organizationId])
  @@index([date])
  @@index([status])
}

enum DeliveryStatus {
  ASSIGNED
  IN_PROGRESS
  NEARBY
  COMPLETED
  FAILED
  CANCELLED
}

enum RouteStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ─── Returns ───

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  IN_TRANSIT
  RECEIVED
  REFUNDED
  EXCHANGED
}

enum ReturnReason {
  DEFECTIVE
  WRONG_ITEM
  NOT_AS_DESCRIBED
  CHANGED_MIND
  SIZE_ISSUE
  ARRIVED_LATE
  OTHER
}

model Return {
  id             String       @id @default(uuid())
  orderId        String
  orderItemId    String?
  status         ReturnStatus @default(REQUESTED)
  reason         ReturnReason
  reasonDetails  String?      // Descripción adicional del cliente
  photos         String[]     // URLs de fotos
  
  // Cantidades
  quantity       Int          @default(1)
  refundAmount   Float?
  
  // Estado físico
  receivedAt     DateTime?
  receivedBy     String?      // Quién recibió la devolución
  condition      String?      // Estado en que llegó: good, damaged, used
  
  // Resolución
  resolution     String?      // refund, exchange, store_credit, repair
  resolutionNotes String?
  resolvedAt     DateTime?
  
  // Pickup
  pickupAddress  String?
  pickupScheduledAt DateTime?
  pickupCompletedAt DateTime?
  pickupDriverId String?
  
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  pickupDriver Driver?     @relation(fields: [pickupDriverId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([orderId])
  @@index([status])
  @@index([pickupDriverId])
}

// ─── Inventory ───

model Inventory {
  id                String @id @default(uuid())
  catalogItemId     String @unique
  quantity          Int    @default(0)
  lowStockThreshold Int    @default(5)

  catalogItem CatalogItem     @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  movements   StockMovement[]
  batches     InventoryBatch[]
}

model InventoryBatch {
  id                String   @id @default(uuid())
  inventoryId       String
  batchNumber       String
  quantity          Int
  remainingQuantity Int      @default(0)
  costPerUnit       Float?
  receivedAt        DateTime @default(now())
  expiresAt         DateTime?
  supplier          String?
  notes             String?
  createdBy         String?
  createdAt         DateTime @default(now())

  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([inventoryId])
  @@index([batchNumber])
}

model StockMovement {
  id          String       @id @default(uuid())
  inventoryId String
  type        MovementType
  quantity    Int
  reason      String?
  reference   String?
  createdBy   String?
  createdAt   DateTime     @default(now())

  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([inventoryId])
}

// ─── Campaigns & Discounts ───

model Campaign {
  id             String   @id @default(uuid())
  name           String
  description    String?
  startDate      DateTime
  endDate        DateTime
  active         Boolean  @default(true)
  autoApply      Boolean  @default(false)
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  discounts    Discount[]

  @@index([organizationId])
  @@index([active, startDate, endDate])
}

model Discount {
  id         String       @id @default(uuid())
  type       DiscountType
  value      Float
  code       String?
  maxUses    Int?
  usedCount  Int          @default(0)
  campaignId String

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([code])
  @@index([campaignId])
}

// ─── Company Settings ───

model SystemSetting {
  id             String @id @default(uuid())
  key            String
  value          String
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
}

model ApiKey {
  id             String   @id @default(uuid())
  name           String
  keyHash        String   @unique
  keyPrefix      String
  permissions    String[] @default([])
  active         Boolean  @default(true)
  lastUsedAt     DateTime?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([keyHash])
}

// ─── Content Site Web ───

model HomepageSection {
  id             String   @id @default(uuid())
  type           String   // hero, featured, new_arrivals, promo, collections
  title          String?
  order          Int      @default(0)
  active         Boolean  @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slides       HomepageSlide[]
  spotlights   HomepageProductSpotlight[]
  banners      HomepageBanner[]

  @@index([organizationId])
  @@index([type])
}

model HomepageSlide {
  id              String  @id @default(uuid())
  sectionId       String
  imageUrl        String
  title           String?
  subtitle        String?
  ctaText         String?
  ctaLink         String?
  bgColor         String? // Color de fondo del slide
  buttonColor     String? // Color del botón
  buttonTextColor String? // Color del texto del botón
  textColor       String? // Color del texto principal
  order           Int     @default(0)
  active          Boolean @default(true)

  section HomepageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
}

model HomepageProductSpotlight {
  id            String @id @default(uuid())
  sectionId     String
  catalogItemId String
  order         Int    @default(0)

  section     HomepageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  catalogItem CatalogItem     @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)

  @@unique([sectionId, catalogItemId])
  @@index([sectionId])
  @@index([catalogItemId])
}

model HomepageBanner {
  id             String  @id @default(uuid())
  sectionId      String?
  imageUrl       String?
  title          String?
  description    String?
  link           String?
  position       String? // ej: "top", "middle", "bottom"
  active         Boolean @default(true)
  order          Int     @default(0)
  organizationId String

  organization  Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  section       HomepageSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([sectionId])
}

// ─── Customers ───

model Customer {
  id             String   @id @default(uuid())
  name           String
  email          String
  phone          String?
  document       String?  // DNI/RUC/CUIT/etc
  documentType   String?  // dni, ruc, passport, etc
  active         Boolean  @default(true)
  notes          String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  addresses    CustomerAddress[]
  orders       Order[]

  @@unique([email, organizationId])
  @@index([organizationId])
  @@index([document])
}

model CustomerAddress {
  id         String  @id @default(uuid())
  customerId String
  label      String  // Casa, Trabajo, etc
  street     String
  city       String
  state      String?
  zip        String?
  country    String  @default("AR")
  isDefault  Boolean @default(false)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

// ─── Payments ───

model Payment {
  id             String        @id @default(uuid())
  orderId        String
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  amount         Float
  currency       String        @default("ARS")
  reference      String?       // Referencia interna
  externalId     String?       // ID del proveedor de pago
  externalData   String?       // JSON string con data del proveedor
  paidAt         DateTime?
  refundedAt     DateTime?
  failureReason  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([externalId])
}

// ─── Shipping Methods ───

model ShippingMethod {
  id             String  @id @default(uuid())
  name           String
  description    String?
  price          Float   @default(0)
  estimatedDays  Int?    // Días estimados de entrega
  active         Boolean @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@index([organizationId])
}

// ─── Locations / Branches ───

model Location {
  id             String  @id @default(uuid())
  name           String
  address        String
  city           String?
  state          String?
  zip            String?
  country        String?
  phone          String?
  email          String?
  latitude       Float?
  longitude      Float?
  isMain         Boolean @default(false)
  active         Boolean @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([active])
}
