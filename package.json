{
  "name": "cms-web-manager",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @cms/backend --filter @cms/frontend --parallel dev",
    "dev:backend": "pnpm --filter @cms/backend dev",
    "dev:frontend": "pnpm --filter @cms/frontend dev",
    "build:shared": "pnpm --filter @cms/shared build",
    "build:backend": "pnpm --filter @cms/backend build",
    "build:frontend": "pnpm --filter @cms/frontend build",
    "build": "pnpm build:shared && pnpm --parallel build:backend build:frontend",
    "db:generate": "pnpm --filter @cms/backend exec prisma generate",
    "db:push": "pnpm --filter @cms/backend exec prisma db push --accept-data-loss",
    "db:migrate": "pnpm --filter @cms/backend exec prisma migrate deploy",
    "db:seed": "pnpm --filter @cms/backend exec prisma db seed",
    "lint": "pnpm --parallel -r lint"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@nestjs/core", "@prisma/client", "@prisma/engines", "prisma", "esbuild"]
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
