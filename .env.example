# ─── Database ───
DATABASE_URL="postgresql://user:password@localhost:5432/cms_web?schema=public"

# ─── JWT ───
JWT_SECRET="change-this-to-a-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── S3-compatible Storage (MinIO / AWS S3) ───
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET=cms-media
S3_PUBLIC_URL=http://localhost:9000/cms-media

# ─── Frontend ───
NEXT_PUBLIC_API_URL=http://localhost:4002/api

# NEXTAUTH_URL: solo necesario en producción. En desarrollo NextAuth infiere la URL del request.
# NEXTAUTH_URL=https://tudominio.com

# NEXTAUTH_SECRET: obligatorio. Genera uno con: openssl rand -base64 32
NEXTAUTH_SECRET="change-this-to-a-random-secret-min-32-chars"
